{
  "manifest_version": 3,
  "name": "ResumeFit",
  "description": "Analyzes job postings and recommends your best matching resume. Fully local \u2014 no data sent anywhere.",
  "version": "3.1",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    }
  },
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://*.linkedin.com/jobs/*",
        "https://*.greenhouse.io/*",
        "https://job-boards.greenhouse.io/*",
        "https://boards.greenhouse.io/*",
        "https://*.lever.co/*",
        "https://*.ashbyhq.com/*",
        "https://*.myworkdayjobs.com/*",
        "https://*.workday.com/*",
        "https://*.smartrecruiters.com/*",
        "https://*.indeed.com/*",
        "https://*.jobvite.com/*",
        "https://*.icims.com/*",
        "https://*.taleo.net/*",
        "https://*.oraclecloud.com/hcmUI/*",
        "https://*.rippling.com/jobs/*",
        "https://*.wellfound.com/jobs/*",
        "https://*.ycombinator.com/jobs/*",
        "https://jobs.ycombinator.com/*",
        "https://*.careers.microsoft.com/*",
        "https://careers.google.com/*",
        "https://*.amazon.jobs/*",
        "https://*.meta.com/careers/*",
        "https://*.apple.com/careers/*",
        "https://*.netflix.com/jobs/*"
      ],
      "js": [
        "floatingpanel.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "icons/*"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}