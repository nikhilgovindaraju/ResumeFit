{
  "manifest_version": 3,
  "name": "ResumeFit",
  "description": "Analyzes job postings and recommends your best matching resume. Fully local — no data sent anywhere.",
  "version": "1.0",
  "icons": {
    "16":  "icons/icon16.png",
    "32":  "icons/icon32.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "32":  "icons/icon32.png",
      "48":  "icons/icon48.png"
    }
  },
  "permissions": ["storage", "activeTab", "scripting"]
}